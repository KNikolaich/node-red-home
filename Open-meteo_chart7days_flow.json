    {
        "id": "56b09629a5596c01",
        "type": "ui-template",
        "z": "1b4d499daab9d751",
        "g": "df680e52eca81b91",
        "group": "4bbdd02ff5de4f4c",
        "page": "",
        "ui": "",
        "name": "charts open meteo",
        "order": 2,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n\n<div class=\"forecast-wrap\" v-if=\"data.length\">\n\n    <!-- Date tabs -->\n    <div class=\"date-tabs\">\n        <div \n            v-for=\"(dateItem, index) in uniqueDates\" \n            :key=\"index\"\n            class=\"date-tab\"\n            :class=\"{ active: dateItem.date === selectedDate }\"\n            @click=\"selectDate(dateItem.date)\"\n        >\n            {{ dateItem.day }}<br>\n            <span class=\"tab-date\">{{ dateItem.date }}</span>\n        </div>\n    </div>\n\n    <!-- Hours -->\n    <div class=\"forecast-hours\">\n        <div \n            v-for=\"(item,index) in filteredData\" \n            :key=\"'h'+index\" \n            class=\"hour-cell\"\n            :style=\"{ width: columnWidth + 'px' }\"\n        >\n            {{item.hour}}\n        </div>\n    </div>\n\n    <!-- Weather icons -->\n    <div class=\"forecast-icons\">\n        <div \n            v-for=\"(item,index) in filteredData\" \n            :key=\"'i'+index\" \n            class=\"icon-cell\"\n            :style=\"{ width: columnWidth + 'px' }\"\n        >\n            {{item.icon}}\n        </div>\n    </div>\n\n    <!-- Chart -->\n    <div class=\"chart-box\">\n        <svg \n            :width=\"chartWidth\" \n            height=\"365\" \n            class=\"chart-svg\"\n        >\n            <!-- Horizontal grid -->\n            <line v-for=\"n in 13\" :key=\"'hgrid'+n\" \n                  x1=\"72\" :y1=\"32 + n*24\" \n                  :x2=\"chartWidth - 78\" :y2=\"32 + n*24\" class=\"grid\"/>\n\n            <!-- Vertical grid -->\n            <line v-for=\"n in filteredData.length\" :key=\"'vgrid'+n\"\n                  :x1=\"72 + n*columnWidth\" y1=\"32\" \n                  :x2=\"72 + n*columnWidth\" y2=\"335\" class=\"grid\"/>\n\n            <!-- Temperature Y-axis -->\n            <g class=\"temp-axis\">\n                <line x1=\"67\" y1=\"32\" x2=\"67\" y2=\"335\" stroke=\"#777\" stroke-width=\"1.5\"/>\n                <template v-for=\"(tick, i) in tempTicks\" :key=\"'tt'+i\">\n                    <line :x1=\"62\" :y1=\"tempY(tick)\" :x2=\"72\" :y2=\"tempY(tick)\" stroke=\"#888\" stroke-width=\"1\"/>\n                    <text :x=\"54\" :y=\"tempY(tick) + 4\" text-anchor=\"end\" fill=\"#ccc\" font-size=\"11.5\">\n                        {{tick}}\n                    </text>\n                </template>\n                <text x=\"38\" y=\"24\" fill=\"#ddd\" font-size=\"13\" font-weight=\"bold\">°C</text>\n            </g>\n\n            <!-- Precipitation Y-axis -->\n            <g class=\"rain-axis\">\n                <line :x1=\"chartWidth - 72\" y1=\"32\" :x2=\"chartWidth - 72\" y2=\"335\" stroke=\"#777\" stroke-width=\"1.5\"/>\n                <template v-for=\"(tick, i) in rainTicks\" :key=\"'rt'+i\">\n                    <line :x1=\"chartWidth - 72\" :y1=\"rainY(tick.value)\" :x2=\"chartWidth - 62\" :y2=\"rainY(tick.value)\" stroke=\"#888\" stroke-width=\"1\"/>\n                    <text :x=\"chartWidth - 52\" :y=\"rainY(tick.value) + 4\" text-anchor=\"start\" fill=\"#7eb3ff\" font-size=\"11.5\">\n                        {{tick.label}}\n                    </text>\n                </template>\n                <text :x=\"chartWidth - 68\" y=\"24\" fill=\"#7eb3ff\" font-size=\"13\" font-weight=\"bold\">мм</text>\n            </g>\n\n            <!-- Rain bars -->\n            <rect\n                v-for=\"(item,index) in filteredData\"\n                :key=\"'rain'+index\"\n                :x=\"72 + index*columnWidth + 5\"\n                :y=\"rainY(item.rain)\"\n                :width=\"columnWidth - 11\"\n                :height=\"335 - rainY(item.rain)\"\n                class=\"rain\"\n            />\n\n            <!-- Temperature line + dots + labels -->\n            <polyline :points=\"tempPoints\" class=\"temp-line\"/>\n            <circle\n                v-for=\"(item,index) in filteredData\"\n                :key=\"'dot'+index\"\n                :cx=\"72 + index*columnWidth + columnWidth/2\"\n                :cy=\"tempY(item.temp)\"\n                r=\"3\"\n                class=\"temp-dot\"\n            />\n            <text\n                v-for=\"(item,index) in filteredData\"\n                :key=\"'templabel'+index\"\n                :x=\"72 + index*columnWidth + columnWidth/2\"\n                :y=\"tempY(item.temp) - 8\"\n                text-anchor=\"middle\"\n                fill=\"#ff4d5c\"\n                font-size=\"10.5\"\n                font-weight=\"600\"\n            >\n                {{Math.round(item.temp)}}\n            </text>\n        </svg>\n    </div>\n\n    <!-- Wind row -->\n    <div class=\"wind-row\">\n        <div class=\"wind-label\">км/ч</div>\n        <div \n            v-for=\"(item,index) in filteredData\" \n            :key=\"'w'+index\" \n            class=\"wind-cell\"\n            :style=\"{ width: columnWidth + 'px' }\"\n        >\n            <div class=\"arrow\" :style=\"'transform:rotate('+item.windDir+'deg)'\">➤</div>\n            <div class=\"speed\">{{Math.round(item.windSpeed)}}</div>\n        </div>\n    </div>\n\n</div>\n\n</template>\n\n<script>\nexport default {\n    data() {\n        return {\n            data: [],\n            selectedDate: null,\n            columnWidth: 44,   // начальное значение\n            minColumn: 30,\n            maxColumn: 64,\n            resizeTimeout: null\n        }\n    },\n    computed: {\n        uniqueDates() {\n            const dates = [];\n            const seen = new Set();\n            this.data.forEach(item => {\n                if (!seen.has(item.date)) {\n                    seen.add(item.date);\n                    dates.push({ date: item.date, day: item.day });\n                }\n            });\n            return dates;\n        },\n\n        filteredData() {\n            if (!this.selectedDate) return this.data;\n            return this.data.filter(item => item.date === this.selectedDate);\n        },\n\n        chartWidth() {\n            const contentWidth = this.filteredData.length * this.columnWidth;\n            return Math.max(520, Math.min(1280, 72 + contentWidth + 82));\n        },\n\n        minTemp() { \n            const temps = this.filteredData.map(x => x.temp);\n            return Math.floor(Math.min(...temps) - 1.5);\n        },\n        maxTemp() { \n            const temps = this.filteredData.map(x => x.temp);\n            return Math.ceil(Math.max(...temps) + 1.5);\n        },\n        maxRain() {\n            return Math.max(5, ...this.filteredData.map(x => Number(x.rain) || 0));\n        },\n\n        tempTicks() {\n            const range = this.maxTemp - this.minTemp;\n            const step = range > 16 ? 3 : 2;\n            const ticks = [];\n            let t = Math.floor(this.minTemp / step) * step;\n            while (t <= this.maxTemp + 1) {\n                ticks.push(t);\n                t += step;\n            }\n            return ticks;\n        },\n\n        rainTicks() {\n            const base = [0, 1, 2, 4, 7, 12, 20, 35];\n            return base.filter(v => v <= this.maxRain * 1.2)\n                       .map(v => ({value: v, label: v}));\n        },\n\n        tempPoints() {\n            return this.filteredData.map((item, i) => \n                (72 + i * this.columnWidth + this.columnWidth / 2) + \",\" + this.tempY(item.temp)\n            ).join(\" \");\n        }\n    },\n    watch: {\n        msg: {\n            deep: true,\n            handler(msg) {\n                if (msg?.payload?.data) {\n                    this.data = msg.payload.data;\n                    if (this.data.length && !this.selectedDate) {\n                        this.selectedDate = this.data[0].date;\n                    }\n                }\n            }\n        },\n        filteredData() {\n            this.updateColumnWidth();\n        }\n    },\n    mounted() {\n        this.updateColumnWidth();\n        window.addEventListener('resize', this.onResize);\n    },\n    beforeDestroy() {\n        window.removeEventListener('resize', this.onResize);\n    },\n    methods: {\n        selectDate(date) {\n            this.selectedDate = date;\n        },\n\n        onResize() {\n            clearTimeout(this.resizeTimeout);\n            this.resizeTimeout = setTimeout(() => {\n                this.updateColumnWidth();\n            }, 150);\n        },\n\n        updateColumnWidth() {\n            const container = this.$el;\n            if (!container || !this.filteredData.length) return;\n\n            const availableWidth = container.clientWidth - 72 - 82; // отступы под оси\n            const idealWidth = availableWidth / this.filteredData.length;\n\n            this.columnWidth = Math.max(this.minColumn, Math.min(this.maxColumn, Math.floor(idealWidth)));\n        },\n\n        tempY(temp) {\n            const h = 303;\n            const range = this.maxTemp - this.minTemp || 1;\n            return 32 + h - ((temp - this.minTemp) / range) * h;\n        },\n        rainY(rain) {\n            const maxD = Math.max(this.maxRain, 12);\n            const norm = Math.min(rain / maxD, 1);\n            return 335 - Math.pow(norm, 0.65) * 303;\n        }\n    }\n}\n</script>\n\n<style>\n.forecast-wrap {\n    background: #151515;\n    color: white;\n    padding: 12px;\n    font-family: Arial, sans-serif;\n    max-width: 100%;\n    box-sizing: border-box;\n}\n\n.date-tabs {\n    display: flex;\n    gap: 6px;\n    flex-wrap: wrap;\n    margin-bottom: 10px;\n}\n\n.date-tab {\n    padding: 8px 12px;\n    background: #252525;\n    border: 1px solid #444;\n    border-radius: 6px;\n    text-align: center;\n    cursor: pointer;\n    font-size: 13px;\n    flex: 1;\n    transition: all 0.2s;\n}\n\n.date-tab:hover { background: #333; border-color: #666; }\n.date-tab.active {\n    background: #ff4d5c;\n    border-color: #ff4d5c;\n    color: white;\n}\n\n.tab-date { font-size: 11px; opacity: 0.9; }\n\n/* Rows */\n.forecast-hours,\n.forecast-icons,\n.wind-row {\n    display: flex;\n    width: fit-content;\n    padding-left: 72px;\n}\n\n.hour-cell,\n.icon-cell,\n.wind-cell {\n    flex-shrink: 0;\n    text-align: center;\n    box-sizing: border-box;\n}\n\n.hour-cell { \n    font-size: 12.5px; \n    color: #ddd; \n    line-height: 1.1;\n    padding: 3px 0;\n    overflow: hidden;\n}\n\n.icon-cell { \n    font-size: 26px; \n    height: 40px; \n    line-height: 40px; \n}\n\n.chart-box { \n    margin: 6px 0 10px 0; \n    width: fit-content; \n}\n\n.chart-svg {\n    background: #1a1a1a;\n    overflow: visible;\n}\n\n.grid { stroke: #333; stroke-width: 1; }\n\n.temp-line { fill: none; stroke: #ff4d5c; stroke-width: 3.5; stroke-linejoin: round; }\n.temp-dot { fill: #ff4d5c; }\n.rain { fill: #5a9eff; opacity: 0.9; }\n\n.wind-label {\n    position: absolute;\n    left: 12px;\n    width: 60px;\n    font-size: 11px;\n    color: #aaa;\n    padding-top: 4px;\n    text-align: center;\n}\n\n.wind-cell {\n    font-size: 11px;\n    padding-top: 2px;\n}\n\n.arrow {\n    color: #7cff5f;\n    font-size: 19px;\n    height: 22px;\n    line-height: 22px;\n}\n\n.speed { color: #ccc; }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 950,
        "y": 500,
        "wires": [
