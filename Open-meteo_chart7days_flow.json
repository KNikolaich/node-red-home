    {
        "id": "035f0b6c677abedb",
        "type": "function",
        "z": "1b4d499daab9d751",
        "g": "df680e52eca81b91",
        "name": "mapping data",
        "func": "const h = msg.payload.hourly;\n\nfunction icon(code){\n\n    const map = {\n        0:\"☀️\",\n        1:\"🌤️\",\n        2:\"⛅\",\n        3:\"☁️\",\n        45:\"🌫️\",\n        48:\"🌫️\",\n        51:\"🌦️\",\n        53:\"🌦️\",\n        55:\"🌦️\",\n        61:\"🌧️\",\n        63:\"🌧️\",\n        65:\"🌧️\",\n        71:\"❄️\",\n        73:\"❄️\",\n        75:\"❄️\",\n        80:\"🌦️\",\n        81:\"🌧️\",\n        82:\"🌧️\",\n        95:\"⛈️\",\n        96:\"⛈️\",\n        99:\"⛈️\"\n    };\n\n    return map[code] || \"❔\";\n}\n\nconst daysRu = [\n    \"Вс\",\"Пн\",\"Вт\",\"Ср\",\"Чт\",\"Пт\",\"Сб\"\n];\n\nvar data = h.time.map((t,i)=>{\n\n    const d = new Date(t);\n\n    return {\n        time: t,\n        day: daysRu[d.getDay()],\n        date: String(d.getDate()).padStart(2,\"0\") + \".\" +\n              String(d.getMonth()+1).padStart(2,\"0\"),\n        hour: d.getHours(),\n\n        temp: h.temperature_2m[i],\n        feels: h.apparent_temperature[i],\n\n        rain: h.precipitation[i],\n        rainProb: h.precipitation_probability[i],\n\n        humidity: h.relative_humidity_2m[i],\n\n        windSpeed: h.windspeed_10m[i],\n        windDir: h.winddirection_10m[i],\n\n        weatherCode: h.weathercode[i],\n        icon: icon(h.weathercode[i])\n    };\n});\n\nmsg.payload = { \"data\" : data, \"units\": msg.payload.hourly_units};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 680,
        "y": 500,
        "wires": [
