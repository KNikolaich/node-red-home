<template>

<div class="forecast-wrap" v-if="data.length">

    <!-- Date tabs -->
    <div class="date-tabs">
        <div 
            v-for="(dateItem, index) in uniqueDates" 
            :key="index"
            class="date-tab"
            :class="{ active: dateItem.date === selectedDate }"
            @click="selectDate(dateItem.date)"
        >
            {{ dateItem.day }}<br>
            <span class="tab-date">{{ dateItem.date }}</span>
        </div>
    </div>

    <!-- Hours -->
    <div class="forecast-hours">
        <div 
            v-for="(item,index) in filteredData" 
            :key="'h'+index" 
            class="hour-cell"
            :style="{ width: columnWidth + 'px' }"
        >
            {{item.hour}}
        </div>
    </div>

    <!-- Weather icons -->
    <div class="forecast-icons">
        <div 
            v-for="(item,index) in filteredData" 
            :key="'i'+index" 
            class="icon-cell"
            :style="{ width: columnWidth + 'px' }"
        >
            {{item.icon}}
        </div>
    </div>

    <!-- Chart -->
    <div class="chart-box">
        <svg 
            :width="chartWidth" 
            height="365" 
            class="chart-svg"
        >
            <!-- Dynamic full-width horizontal grid -->
            <line 
                v-for="(tick, i) in tempTicks" 
                :key="'tempgrid'+i"
                x1="138" 
                :y1="tempY(tick)" 
                :x2="chartContentRight"
                :y2="tempY(tick)" 
                class="temp-grid-line"
            />

            <line 
                v-for="(tick, i) in rainTicks" 
                :key="'raingrid'+i"
                x1="138" 
                :y1="rainY(tick.value)" 
                :x2="chartContentRight"
                :y2="rainY(tick.value)" 
                class="rain-grid-line"
            />

            <!-- Vertical dashed grid -->
            <line 
                v-for="n in filteredData.length" 
                :key="'vgrid'+n"
                :x1="138 + n*columnWidth" 
                y1="32" 
                :x2="138 + n*columnWidth" 
                y2="335" 
                class="v-grid"
            />

            <!-- Rain Y-axis (left) -->
            <g class="rain-axis">
                <line x1="72" y1="32" x2="72" y2="335" stroke="#777" stroke-width="1.5"/>
                <template v-for="(tick, i) in rainTicks" :key="'rt'+i">
                    <line :x1="67" :y1="rainY(tick.value)" :x2="77" :y2="rainY(tick.value)" stroke="#888" stroke-width="1"/>
                    <text :x="62" :y="rainY(tick.value) + 4" text-anchor="end" fill="#7eb3ff" font-size="11.5">
                        {{tick.label}}
                    </text>
                </template>
                <text x="45" y="24" fill="#7eb3ff" font-size="13" font-weight="bold">мм</text>
            </g>

            <!-- Temperature Y-axis -->
            <g class="temp-axis">
                <line x1="112" y1="32" x2="112" y2="335" stroke="#777" stroke-width="1.5"/>
                <template v-for="(tick, i) in tempTicks" :key="'tt'+i">
                    <line :x1="107" :y1="tempY(tick)" :x2="117" :y2="tempY(tick)" stroke="#888" stroke-width="1"/>
                    <text :x="99" :y="tempY(tick) + 4" text-anchor="end" fill="#ccc" font-size="11.5">
                        {{tick}}
                    </text>
                </template>
                <text x="85" y="24" fill="#ddd" font-size="13" font-weight="bold">°C</text>
            </g>

            <!-- Rain bars -->
            <rect
                v-for="(item,index) in filteredData"
                :key="'rain'+index"
                :x="138 + index*columnWidth + 5"
                :y="rainY(item.rain)"
                :width="columnWidth - 11"
                :height="335 - rainY(item.rain)"
                class="rain"
            />

            <!-- Temperature line -->
            <polyline :points="tempPoints" class="temp-line"/>
            
            <!-- Temperature dots -->
            <circle
                v-for="(item,index) in filteredData"
                :key="'dot'+index"
                :cx="138 + index*columnWidth + columnWidth/2"
                :cy="tempY(item.temp)"
                r="3"
                class="temp-dot"
            />

            <!-- Temperature labels -->
            <text
                v-for="(item,index) in filteredData"
                :key="'templabel'+index"
                :x="138 + index*columnWidth + columnWidth/2"
                :y="tempY(item.temp) - 8"
                text-anchor="middle"
                fill="#ff4d5c"
                font-size="10.5"
                font-weight="600"
            >
                {{Math.round(item.temp)}}
            </text>
        </svg>
    </div>

    <!-- Wind row -->
    <div class="wind-row">
        <div class="wind-label">км/ч</div>
        <div 
            v-for="(item,index) in filteredData" 
            :key="'w'+index" 
            class="wind-cell"
            :style="{ width: columnWidth + 'px' }"
        >
            <div class="arrow" :style="'transform:rotate('+item.windDir+'deg)'">➤</div>
            <div class="speed">{{Math.round(item.windSpeed)}}</div>
        </div>
    </div>

</div>

</template>

<script>
export default {
    data() {
        return {
            data: [],
            selectedDate: null,
            columnWidth: 44,
            minColumn: 30,
            maxColumn: 64,
            resizeTimeout: null
        }
    },
    computed: {
        uniqueDates() {
            const dates = [];
            const seen = new Set();
            this.data.forEach(item => {
                if (!seen.has(item.date)) {
                    seen.add(item.date);
                    dates.push({ date: item.date, day: item.day });
                }
            });
            return dates;
        },

        filteredData() {
            if (!this.selectedDate) return this.data;
            return this.data.filter(item => item.date === this.selectedDate);
        },

        chartContentRight() {
            return 138 + this.filteredData.length * this.columnWidth + 8;
        },

        chartWidth() {
            return Math.max(580, Math.min(1400, this.chartContentRight + 55));
        },

        minTemp() { 
            const temps = this.filteredData.map(x => x.temp);
            return Math.floor(Math.min(...temps) - 1.5);
        },
        maxTemp() { 
            const temps = this.filteredData.map(x => x.temp);
            return Math.ceil(Math.max(...temps) + 1.5);
        },
        maxRain() {
            return Math.max(5, ...this.filteredData.map(x => Number(x.rain) || 0));
        },

        tempTicks() {
            const range = this.maxTemp - this.minTemp;
            const step = range > 16 ? 3 : 2;
            const ticks = [];
            let t = Math.floor(this.minTemp / step) * step;
            while (t <= this.maxTemp + 1) {
                ticks.push(t);
                t += step;
            }
            return ticks;
        },

        rainTicks() {
            const base = [0, 1, 2, 4, 7, 12, 20, 35];
            return base.filter(v => v <= this.maxRain * 1.2)
                       .map(v => ({value: v, label: v}));
        },

        tempPoints() {
            return this.filteredData.map((item, i) => 
                (138 + i * this.columnWidth + this.columnWidth / 2) + "," + this.tempY(item.temp)
            ).join(" ");
        }
    },
    watch: {
        msg: {
            deep: true,
            handler(msg) {
                if (msg?.payload?.data) {
                    this.data = msg.payload.data;
                    if (this.data.length && !this.selectedDate) {
                        this.selectedDate = this.data[0].date;
                    }
                    this.$nextTick(() => this.updateColumnWidth());
                }
            }
        },
        filteredData() {
            this.$nextTick(() => this.updateColumnWidth());
        }
    },
    mounted() {
        this.$nextTick(() => this.updateColumnWidth());
        window.addEventListener('resize', this.onResize);
    },
    beforeDestroy() {
        window.removeEventListener('resize', this.onResize);
    },
    methods: {
        selectDate(date) {
            this.selectedDate = date;
        },

        onResize() {
            clearTimeout(this.resizeTimeout);
            this.resizeTimeout = setTimeout(() => this.updateColumnWidth(), 120);
        },

        updateColumnWidth() {
            const container = this.$el;
            if (!container || !this.filteredData.length) return;

            const available = container.clientWidth - 138 - 70;
            const ideal = available / this.filteredData.length;
            this.columnWidth = Math.max(this.minColumn, Math.min(this.maxColumn, Math.floor(ideal)));
        },

        tempY(temp) {
            const h = 303;
            const range = this.maxTemp - this.minTemp || 1;
            return 32 + h - ((temp - this.minTemp) / range) * h;
        },
        rainY(rain) {
            const maxD = Math.max(this.maxRain, 12);
            const norm = Math.min(rain / maxD, 1);
            return 335 - Math.pow(norm, 0.65) * 303;
        }
    }
}
</script>

<style>
.forecast-wrap {
    background: #151515;
    color: white;
    padding: 12px;
    font-family: Arial, sans-serif;
    max-width: 100%;
    box-sizing: border-box;
}

.date-tabs {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 10px;
}

.date-tab {
    padding: 8px 12px;
    background: #252525;
    border: 1px solid #444;
    border-radius: 6px;
    text-align: center;
    cursor: pointer;
    font-size: 13px;
    flex: 1;
    transition: all 0.2s;
}

.date-tab:hover { background: #333; border-color: #666; }
.date-tab.active {
    background: #ff4d5c;
    border-color: #ff4d5c;
    color: white;
}

.tab-date { font-size: 11px; opacity: 0.9; }

.forecast-hours,
.forecast-icons,
.wind-row {
    display: flex;
    width: fit-content;
    padding-left: 138px;
}

.hour-cell,
.icon-cell,
.wind-cell {
    flex-shrink: 0;
    text-align: center;
    box-sizing: border-box;
}

.hour-cell { 
    font-size: 12.5px; 
    color: #ddd; 
    line-height: 1.1;
    padding: 3px 0;
    overflow: hidden;
}

.icon-cell { 
    font-size: 26px; 
    height: 40px; 
    line-height: 40px; 
}

.chart-box { 
    margin: 6px 0 10px 0; 
    width: fit-content; 
}

.chart-svg {
    background: #1a1a1a;
    overflow: visible;
}

/* Grid lines */
.temp-grid-line {
    stroke: #ff8a9e;
    stroke-width: 1;
    opacity: 0.4;
}

.rain-grid-line {
    stroke: #7eb3ff;
    stroke-width: 1;
    stroke-dasharray: 4,3;
    opacity: 0.45;
}

.v-grid {
    stroke: #444;
    stroke-width: 1;
    stroke-dasharray: 3,2;
    opacity: 0.35;
}

.temp-line { fill: none; stroke: #ff4d5c; stroke-width: 3.5; stroke-linejoin: round; }
.temp-dot { fill: #ff4d5c; }
.rain { fill: #5a9eff; opacity: 0.9; }

.wind-label {
    position: absolute;
    left: 12px;
    width: 60px;
    font-size: 11px;
    color: #aaa;
    padding-top: 4px;
    text-align: center;
}

.wind-cell {
    font-size: 11px;
    padding-top: 2px;
}

.arrow {
    color: #7cff5f;
    font-size: 19px;
    height: 22px;
    line-height: 22px;
}

.speed { color: #ccc; }
</style>
